{
  "_type": "Project",
  "_id": "ILINK_FLOW_PROJECT_01",
  "name": "iLink 微信智能助手消息处理流程",
  "ownedElements": [
    {
      "_type": "UMLModel",
      "_id": "ILINK_FLOW_MODEL_01",
      "_parent": { "$ref": "ILINK_FLOW_PROJECT_01" },
      "name": "iLink Agent",
      "ownedElements": [
        {
          "_type": "UMLActivity",
          "_id": "ILINK_FLOW_ACTIVITY_01",
          "_parent": { "$ref": "ILINK_FLOW_MODEL_01" },
          "name": "用户消息与大模型回复流程",
          "nodes": [
            {
              "_type": "UMLInitialNode",
              "_id": "ILINK_NODE_00",
              "_parent": { "$ref": "ILINK_FLOW_ACTIVITY_01" },
              "name": "开始"
            },
            {
              "_type": "UMLAction",
              "_id": "ILINK_NODE_01",
              "_parent": { "$ref": "ILINK_FLOW_ACTIVITY_01" },
              "name": "微信用户发送文本或图片"
            },
            {
              "_type": "UMLAction",
              "_id": "ILINK_NODE_02",
              "_parent": { "$ref": "ILINK_FLOW_ACTIVITY_01" },
              "name": "iLink SDK 轮询接收消息"
            },
            {
              "_type": "UMLAction",
              "_id": "ILINK_NODE_03",
              "_parent": { "$ref": "ILINK_FLOW_ACTIVITY_01" },
              "name": "原始消息进入全局消息队列"
            },
            {
              "_type": "UMLAction",
              "_id": "ILINK_NODE_04",
              "_parent": { "$ref": "ILINK_FLOW_ACTIVITY_01" },
              "name": "按 userId 路由到对应用户队列"
            },
            {
              "_type": "UMLAction",
              "_id": "ILINK_NODE_05",
              "_parent": { "$ref": "ILINK_FLOW_ACTIVITY_01" },
              "name": "用户虚拟线程收集同批消息（发送间隔不超过 5 秒）"
            },
            {
              "_type": "UMLAction",
              "_id": "ILINK_NODE_06",
              "_parent": { "$ref": "ILINK_FLOW_ACTIVITY_01" },
              "name": "提取文本并下载图片"
            },
            {
              "_type": "UMLAction",
              "_id": "ILINK_NODE_07",
              "_parent": { "$ref": "ILINK_FLOW_ACTIVITY_01" },
              "name": "组装多模态 List<Content>"
            },
            {
              "_type": "UMLAction",
              "_id": "ILINK_NODE_08",
              "_parent": { "$ref": "ILINK_FLOW_ACTIVITY_01" },
              "name": "调用 Qwen 多模态模型"
            },
            {
              "_type": "UMLAction",
              "_id": "ILINK_NODE_09",
              "_parent": { "$ref": "ILINK_FLOW_ACTIVITY_01" },
              "name": "获取大模型回复"
            },
            {
              "_type": "UMLAction",
              "_id": "ILINK_NODE_10",
              "_parent": { "$ref": "ILINK_FLOW_ACTIVITY_01" },
              "name": "iLink SDK 发送文本回复"
            },
            {
              "_type": "UMLAction",
              "_id": "ILINK_NODE_11",
              "_parent": { "$ref": "ILINK_FLOW_ACTIVITY_01" },
              "name": "微信用户收到助手回复"
            },
            {
              "_type": "UMLActivityFinalNode",
              "_id": "ILINK_NODE_12",
              "_parent": { "$ref": "ILINK_FLOW_ACTIVITY_01" },
              "name": "结束"
            }
          ],
